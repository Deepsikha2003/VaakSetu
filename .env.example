# VaakSetu API Key Template
# Copy this file to .env and fill in your keys

# Claude API (Anthropic) — Free trial available
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Twilio (Free trial account)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Database URI (SQLite for demo, PostgreSQL for production)
DATABASE_URL=sqlite:///./vaaksetu.db

# Server Config
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Whisper Model Size (tiny/base/small/medium)
WHISPER_MODEL=base

# Feature Flags
ENABLE_EMOTION_DETECTION=true
ENABLE_NOISE_ANALYSIS=true
ENABLE_TTS=true
