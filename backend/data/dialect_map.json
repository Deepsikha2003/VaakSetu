        "come quickly": "ಬೇಗ ಬನ್ನಿ"
      }
    },
    "hyderabad_karnataka": {
      "region": "Gulbarga, Raichur, Bidar",
      "characteristic": "Urdu/Deccani influence",
      "examples": {
